# ================================================
# Victory Coffee - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ================================================

# --- Database ---
# Local development (replace with your postgres password)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/victory_coffee_dev"

# Cloud (Supabase) — use this for production
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# --- Authentication ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace_with_a_random_64_char_hex_string"
JWT_EXPIRES_IN="8h"

# --- App ---
NEXT_PUBLIC_APP_NAME="Victory Coffee FMS"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# --- Email (SMTP) ---
# Used for dispatch confirmations and hulling ratio alerts
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@email.com"
SMTP_PASS="your_app_password"
SMTP_FROM="Victory Coffee Factory <your@email.com>"

# Manager email — receives hulling ratio alerts when ratio < 45%
MANAGER_EMAIL="manager@victorycoffee.ug"

# --- WhatsApp (Twilio) ---
# Used for farmer receipts and buyer order status messages
# Sign up at https://twilio.com and enable WhatsApp sandbox or a business number
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
# Sandbox: whatsapp:+14155238886  |  Production: whatsapp:+256xxxxxxxxx
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
